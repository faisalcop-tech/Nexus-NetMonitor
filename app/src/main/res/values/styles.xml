<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#00c8ff</item>
        <item name="colorPrimaryDark">#030c16</item>
        <item name="colorAccent">#00ffdf</item>
        <item name="android:windowBackground">#030c16</item>
        <item name="android:statusBarColor">#030c16</item>
        <item name="android:navigationBarColor">#030c16</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:ignore="NewApi">shortEdges</item>
    </style>
</resources>
